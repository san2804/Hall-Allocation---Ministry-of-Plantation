<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="BookingSystem.App.Views.NewBookingView">

    <UserControl.Styles>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="PlaceholderForeground" Value="#999999"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="PlaceholderForeground" Value="#999999"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
        <Style Selector="TimePicker">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="1.5*, 1*" Margin="0">
        <!-- Left Side: Form -->
        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="30" Margin="0,0,20,0" BoxShadow="0 4 12 0 #0D000000">
            <ScrollViewer>
                <StackPanel Spacing="25">
                    <TextBlock Text="New Booking" FontSize="22" FontWeight="Bold" Foreground="#1A1A1A"/>
                    
                    <StackPanel>
                        <TextBlock Text="Conference Hall" Classes="FieldLabel"/>
                        <Border Background="#F8F9FA" Padding="12,10" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
                            <TextBlock Text="Main Conference Hall" VerticalAlignment="Center" FontWeight="Medium" Foreground="#333"/>
                        </Border>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, 20, *">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Date" Classes="FieldLabel"/>
                            <DatePicker />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Start Time" Classes="FieldLabel"/>
                            <TimePicker />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*, 20, *">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="End Time" Classes="FieldLabel"/>
                            <TimePicker />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Purpose" Classes="FieldLabel"/>
                            <TextBox PlaceholderText="e.g. Staff Meeting" />
                        </StackPanel>
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="Additional Information (Optional)" Classes="FieldLabel"/>
                        <TextBox Height="100" TextWrapping="Wrap" AcceptsReturn="True" PlaceholderText="Any specific requirements..."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                        <Button Content="Check Availability" Classes="Primary" Padding="25,12"/>
                        <Button Content="Reset" Padding="25,12" Background="#F0F0F0" Foreground="#333" FontWeight="Bold" CornerRadius="6"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Side: Hall Information -->
        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="30" BoxShadow="0 4 12 0 #0D000000">
            <StackPanel Spacing="25">
                <TextBlock Text="Hall Information" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                
                <Border CornerRadius="8" ClipToBounds="True">
                    <Image Source="avares://BookingSystem.App/Assets/login_bg.png" Height="200" Stretch="UniformToFill"/>
                </Border>

                <TextBlock Text="Main Conference Hall" FontSize="18" FontWeight="Bold" Foreground="#1a5d38"/>
                
                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto" Margin="0,10,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Capacity:" FontWeight="SemiBold" Foreground="#666" Margin="0,0,15,10"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="50 People" Foreground="#333"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Location:" FontWeight="SemiBold" Foreground="#666" Margin="0,0,15,10"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Ministry of Plantation" Foreground="#333"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Facilities:" FontWeight="SemiBold" Foreground="#666" Margin="0,0,15,10"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Projector, Sound System, WiFi, Whiteboard, Air Conditioned" TextWrapping="Wrap" Foreground="#333"/>
                </Grid>

                <Border Background="#E6F4EA" Padding="15" CornerRadius="8">
                    <TextBlock Text="This hall is currently available for your selected time slot." Foreground="#1E8E3E" TextWrapping="Wrap" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>