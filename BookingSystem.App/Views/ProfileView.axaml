<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BookingSystem.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="BookingSystem.App.Views.ProfileView"
             x:DataType="vm:ProfileViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="PlaceholderForeground" Value="#999999"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <!-- Style for disabled TextBoxes to ensure text is still readable -->
        <Style Selector="TextBox:disabled">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="#F5F7F9"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer Padding="0">
        <StackPanel Spacing="30" Margin="0,0,0,30">
            
            <!-- Profile Header Card -->
            <Border Background="White" CornerRadius="12" Padding="40" BoxShadow="0 4 12 0 #0D000000">
                <StackPanel Orientation="Horizontal" Spacing="30">
                    <!-- User Avatar Placeholder -->
                    <Border Width="120" Height="120" CornerRadius="60" Background="#F0F0F0">
                        <TextBlock Text="{Binding Initials}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40" FontWeight="Bold" Foreground="#666666"/>
                    </Border>
                    
                    <StackPanel VerticalAlignment="Center" Spacing="10">
                        <TextBlock Text="{Binding FullName}" FontSize="28" FontWeight="Bold" Foreground="#1A1A1A"/>
                        <TextBlock Text="{Binding Role}" FontSize="16" Foreground="#1a5d38" FontWeight="SemiBold"/>
                        <TextBlock Text="Ministry of Plantation, Sri Lanka" FontSize="14" Foreground="#666"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                            <Button Content="Change Photo" Classes="Primary" Padding="20,10"/>
                            <Button Content="Remove" Classes="Secondary"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Information Grid -->
            <Grid ColumnDefinitions="*, 30, *">
                <!-- Personal Information -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="30" BoxShadow="0 4 12 0 #0D000000">
                    <StackPanel Spacing="25">
                        <TextBlock Text="Personal Information" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                        
                        <StackPanel>
                            <TextBlock Text="Full Name" Classes="FieldLabel"/>
                            <TextBox Text="{Binding FullName}"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Username" Classes="FieldLabel"/>
                            <TextBox Text="{Binding Username}" IsEnabled="False"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Role / Designation" Classes="FieldLabel"/>
                            <TextBox Text="{Binding Role}" IsEnabled="False"/>
                        </StackPanel>

                        <Button Content="Save Changes" 
                                Command="{Binding UpdateProfileCommand}"
                                Classes="Primary" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <!-- Account Security -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="30" BoxShadow="0 4 12 0 #0D000000" VerticalAlignment="Top">
                    <StackPanel Spacing="25">
                        <TextBlock Text="Account Security" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
                        
                        <StackPanel Spacing="15">
                            <TextBlock Text="Change Password" FontWeight="SemiBold" Foreground="#333"/>
                            
                            <StackPanel>
                                <TextBlock Text="New Password" Classes="FieldLabel"/>
                                <TextBox Text="{Binding NewPassword}" PasswordChar="•" PlaceholderText="••••••••"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Confirm New Password" Classes="FieldLabel"/>
                                <TextBox Text="{Binding ConfirmPassword}" PasswordChar="•" PlaceholderText="••••••••"/>
                            </StackPanel>

                            <Button Content="Update Password" 
                                    Command="{Binding UpdatePasswordCommand}"
                                    Classes="Primary" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                        </StackPanel>
                        
                        <Separator Background="#F0F0F0" Margin="0,10"/>
                        
                        <StackPanel Spacing="15">
                            <TextBlock Text="Two-Factor Authentication" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="Add an extra layer of security to your account by enabling two-factor authentication." FontSize="13" Foreground="#666" TextWrapping="Wrap"/>
                            <Button Content="Enable 2FA" Classes="Secondary" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>