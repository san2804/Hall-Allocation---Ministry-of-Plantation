<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             xmlns:vm="clr-namespace:BookingSystem.App.ViewModels"
             xmlns:conv="clr-namespace:BookingSystem.App.Converters"
             x:Class="BookingSystem.App.Views.ReportsView"
             x:DataType="vm:ReportsViewModel">

             <UserControl.Resources>
             <conv:PercentageToHeightConverter x:Key="PercentageToHeightConverter"/>
             </UserControl.Resources>

             <UserControl.Styles>
             <Style Selector="TextBlock.StatLabel">
             <Setter Property="FontSize" Value="14"/>
             <Setter Property="Foreground" Value="#666"/>
             <Setter Property="FontWeight" Value="SemiBold"/>
             </Style>
             <Style Selector="TextBlock.StatValue">
             <Setter Property="FontSize" Value="32"/>
             <Setter Property="FontWeight" Value="Bold"/>
             <Setter Property="Foreground" Value="#1A1A1A"/>
             <Setter Property="Margin" Value="0,5,0,0"/>
             </Style>
             </UserControl.Styles>

             <ScrollViewer>
             <StackPanel Spacing="30">
             <!-- Filter Bar -->
             <Border Background="White" CornerRadius="12" Padding="20" BoxShadow="0 2 5 0 #0A000000">
                <Grid ColumnDefinitions="Auto, Auto, Auto, *, Auto">
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="From Date" FontSize="12" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding FromDate}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="To Date" FontSize="12" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                        <DatePicker SelectedDate="{Binding ToDate}"/>
                    </StackPanel>
                </Grid>
             </Border>

             <!-- Summary Stats -->
             <UniformGrid Columns="5" Rows="1">
                <Border Classes="Card" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Total Bookings" Classes="StatLabel"/>
                        <TextBlock Text="{Binding Stats.TotalBookings}" Classes="StatValue"/>
                    </StackPanel>
                </Border>
                <Border Classes="Card" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Approved" Classes="StatLabel"/>
                        <TextBlock Text="{Binding Stats.ApprovedBookings}" Classes="StatValue" Foreground="#1E8E3E"/>
                    </StackPanel>
                </Border>
                <Border Classes="Card" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Pending" Classes="StatLabel"/>
                        <TextBlock Text="{Binding Stats.PendingBookings}" Classes="StatValue" Foreground="#FA8C16"/>
                    </StackPanel>
                </Border>
                <Border Classes="Card" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Rejected" Classes="StatLabel"/>
                        <TextBlock Text="{Binding Stats.RejectedBookings}" Classes="StatValue" Foreground="#D93025"/>
                    </StackPanel>
                </Border>
                <Border Classes="Card">
                    <StackPanel>
                        <TextBlock Text="Cancelled" Classes="StatLabel"/>
                        <TextBlock Text="{Binding Stats.CancelledBookings}" Classes="StatValue" Foreground="#666"/>
                    </StackPanel>
                </Border>
             </UniformGrid>

             <!-- Detailed Analysis -->
             <Grid ColumnDefinitions="*, *">
                <!-- Bookings by Purpose -->
                <Border Grid.Column="0" Classes="Card" Margin="0,0,15,0">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Bookings by Purpose" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A"/>

                        <ItemsControl ItemsSource="{Binding Stats.ByPurpose}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,15">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding Purpose}" Foreground="#333"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Percentage, StringFormat={}{0}%}" FontWeight="Bold"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding Percentage}" Height="8" CornerRadius="4" Foreground="#1a5d38" Background="#F0F0F0" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Status Distribution -->
                <Border Grid.Column="1" Classes="Card">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Monthly Occupancy" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A"/>
                        <!-- Dynamic representation of occupancy trends -->
                        <ItemsControl ItemsSource="{Binding Stats.MonthlyOccupancy}" Height="230">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="6" Rows="1" VerticalAlignment="Bottom"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Bottom" Margin="10,0">
                                        <Border Background="#1a5d38" 
                                                Height="{Binding Percentage, Converter={StaticResource PercentageToHeightConverter}}" 
                                                VerticalAlignment="Bottom" 
                                                CornerRadius="4,4,0,0">
                                            <ToolTip.Tip>
                                                <TextBlock Text="{Binding Percentage, StringFormat={}{0}%}"/>
                                            </ToolTip.Tip>
                                        </Border>
                                        <TextBlock Text="{Binding Month}" HorizontalAlignment="Center" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
             </Grid>

             <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Export to Excel" Command="{Binding ExportToExcelCommand}" Padding="20,10" Background="#F0F0F0" CornerRadius="6" FontWeight="SemiBold"/>
             </StackPanel>
             </StackPanel>
             </ScrollViewer>
             </UserControl>