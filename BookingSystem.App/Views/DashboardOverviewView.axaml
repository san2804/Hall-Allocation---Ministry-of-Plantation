<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="BookingSystem.App.Views.DashboardOverviewView">

    <UserControl.Styles>
        <Style Selector="Button.QuickAction">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,15"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.QuickAction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#2A7A44"/>
            <Setter Property="TextBlock.Foreground" Value="#2A7A44"/>
        </Style>
    </UserControl.Styles>
    
    <ScrollViewer Padding="30">
        <StackPanel Spacing="30">
            <!-- Stats Row -->
            <UniformGrid Columns="4" Rows="1">
                <Border Classes="StatCard" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Total Bookings" Foreground="#666" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="24" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>
                <Border Classes="StatCard" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Upcoming Bookings" Foreground="#666" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="5" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>
                <Border Classes="StatCard" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Pending Approvals" Foreground="#666" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="3" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>
                <Border Classes="StatCard">
                    <StackPanel>
                        <TextBlock Text="This Month" Foreground="#666" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="7" FontSize="28" FontWeight="Bold" Margin="0,5,0,0" Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Main Grid -->
            <Grid ColumnDefinitions="2*, 1*">
                <Border Grid.Column="0" Classes="Card" Margin="0,0,20,0" VerticalAlignment="Top">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                            <TextBlock Grid.Column="0" Text="Upcoming Bookings" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A"/>
                            <Button Grid.Column="1" Content="View All" Background="Transparent" Foreground="#1E8E3E" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="3*"/><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Date" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Hall" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Time" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Purpose" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Status" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,10"/>
                            <Border Grid.Row="1" Grid.ColumnSpan="5" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Margin="0,0,0,10" Padding="0,0,0,10"/>
                            
                            <!-- Row 1 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="22 May 2024" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Main Conference Hall" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="09:00 AM - 11:00 AM" VerticalAlignment="Center" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Staff Meeting" VerticalAlignment="Center" Margin="0,5"/>
                            <Border Grid.Row="2" Grid.Column="4" Classes="BadgeApproved" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,5">
                                <TextBlock Text="Approved" Classes="BadgeApprovedText"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Classes="Card">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,15"/>
                            <UniformGrid Columns="2" Rows="2">
                                <Button Classes="QuickAction" Content="Check Availability" Margin="0,0,10,10"/>
                                <Button Classes="QuickAction" Content="New Booking" Margin="0,0,0,10"/>
                                <Button Classes="QuickAction" Content="My Bookings" Margin="0,0,10,0"/>
                                <Button Classes="QuickAction" Content="View Halls"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>