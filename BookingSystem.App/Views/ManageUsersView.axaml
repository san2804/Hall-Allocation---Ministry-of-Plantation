<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:BookingSystem.App.ViewModels"
             xmlns:svc="clr-namespace:BookingSystem.App.Services"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="BookingSystem.App.Views.ManageUsersView"
             x:DataType="vm:ManageUsersViewModel">

    <UserControl.Styles>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="TextBlock.FieldLabel">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <StackPanel Spacing="25" Margin="30">
            <!-- Header -->
            <Border Background="White" CornerRadius="12" Padding="25" BoxShadow="0 2 5 0 #0A000000">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Manage Users" FontSize="22" FontWeight="Bold" Foreground="#1A1A1A"/>
                        <TextBlock Text="Add, edit, or remove staff and administrator accounts." Foreground="#666" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                        <TextBox Width="250" Text="{Binding SearchText}" PlaceholderText="Search users..." Foreground="#333" PlaceholderForeground="#999"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Add User Form -->
            <Border Background="White" CornerRadius="12" Padding="25" BoxShadow="0 4 12 0 #0D000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Quick Add User" FontSize="18" FontWeight="Bold" Foreground="#1a5d38" Margin="0,0,0,10"/>
                    <Grid ColumnDefinitions="*, 15, *, 20, Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Full Name" Classes="FieldLabel"/>
                            <TextBox Text="{Binding NewFullName}" PlaceholderText="e.g. Shenal Fernando"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Username" Classes="FieldLabel"/>
                            <TextBox Text="{Binding NewUsername}" PlaceholderText="e.g. shenal@it"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="15">
                            <StackPanel>
                                <TextBlock Text="Password" Classes="FieldLabel"/>
                                <TextBox Text="{Binding NewPassword}" PasswordChar="•" Width="200"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Role" Classes="FieldLabel"/>
                                <ComboBox ItemsSource="{Binding Roles}" 
                                          SelectedItem="{Binding NewRole}"
                                          Width="150"/>
                            </StackPanel>
                            <Button Content="Create Account" 
                                    Command="{Binding AddUserCommand}"
                                    Classes="Primary" 
                                    Padding="25,12" 
                                    VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Users Table -->
            <Border Background="White" CornerRadius="12" Padding="25" BoxShadow="0 4 12 0 #0D000000">
                <StackPanel Spacing="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/> <!-- Name -->
                            <ColumnDefinition Width="3*"/> <!-- Username -->
                            <ColumnDefinition Width="1.5*"/> <!-- Role -->
                            <ColumnDefinition Width="1.5*"/> <!-- Joined -->
                            <ColumnDefinition Width="Auto"/> <!-- Actions -->
                        </Grid.ColumnDefinitions>

                        <!-- Headers -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,15"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Username" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,15"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Role" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,15"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Joined Date" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,15"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Actions" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Users}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="svc:UserDto">
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="5" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" VerticalAlignment="Bottom" Margin="0,0,0,-7"/>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="#E0E0E0">
                                            <TextBlock Text="U" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#666"/>
                                        </Border>
                                        <TextBlock Text="{Binding FullName}" VerticalAlignment="Center" FontWeight="Medium" Foreground="#333"/>
                                    </StackPanel>
                                    
                                    <TextBlock Grid.Column="1" Text="{Binding Username}" VerticalAlignment="Center" Foreground="#333"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Role}" VerticalAlignment="Center" Foreground="#333"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CreatedAt, StringFormat=\{0:dd MMM yyyy\}}" VerticalAlignment="Center" Foreground="#666"/>
                                    
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Button Classes="ActionBtn" Content="🗑️" 
                                                Command="{Binding $parent[UserControl].((vm:ManageUsersViewModel)DataContext).DeleteUserCommand}"
                                                CommandParameter="{Binding Id}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <TextBlock Text="No users found." 
                             IsVisible="{Binding !Users.Count}"
                             HorizontalAlignment="Center" 
                             Margin="0,20" 
                             Foreground="#999"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>